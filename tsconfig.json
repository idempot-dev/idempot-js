{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "maxNodeModuleJsDepth": 0,
    "target": "ESNext",
    "module": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@idempot/core/*": ["./packages/core/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "examples", "tests", "**/*.test.js"]
}
