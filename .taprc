files:
  - "tests/integration/*.test.js"
  - "tests/integration/**/*.test.js"
  - "tests/monorepo/**/*.test.js"
  - "packages/*/tests/**/*.test.js"
  - "packages/frameworks/**/*.test.js"
  - "packages/stores/*/*.test.js"

exclude:
  - "node_modules/**"
  - "**/shared/*.js"
  - "tests/integration/shared/"
  - "tests/runtime/bun/bun-sql-integration.test.js"
