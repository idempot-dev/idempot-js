{
  "name": "hono-idempotency",
  "version": "0.1.0",
  "description": "IETF-compliant idempotency middleware for Hono with pluggable storage backends",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "hono",
    "middleware",
    "idempotency",
    "idempotent",
    "ietf",
    "retry",
    "duplicate-detection"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mroderick/hono-idempotency"
  },
  "license": "MIT",
  "scripts": {
    "build": "npm run build:types && npm run build:copy",
    "build:types": "tsc",
    "build:copy": "cp -r src/* dist/",
    "test": "tap",
    "test:coverage": "tap --coverage-report=html",
    "test:verify-coverage": "tap --statements=100 --branches=100 --functions=100 --lines=100",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md}\"",
    "check": "npm run format:check && npm run lint",
    "example": "node examples/basic-app.js",
    "example:sqlite": "node examples/sqlite-app.js",
    "example:redis": "node examples/redis-app.js",
    "example:bun": "bun run examples/bun-basic-app.js",
    "example:bun:sqlite": "bun run examples/bun-sqlite-app.js",
    "example:lambda:apigateway": "node examples/lambda-apigateway-dynamodb.js",
    "example:lambda:url": "node examples/lambda-url-dynamodb.js",
    "test:bun": "bun test test/bun/",
    "test:bun:coverage": "bun test test/bun/ --coverage",
    "test:lambda": "bun test test/lambda/"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "jsonpath-plus": "^10.3.0",
    "xxhash-wasm": "^1.1.0"
  },
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": "^3.975.0",
    "@aws-sdk/lib-dynamodb": "^3.975.0",
    "hono": ">=4.0.0",
    "ioredis": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.975.0",
    "@aws-sdk/lib-dynamodb": "^3.975.0",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@hono/node-server": "^1.19.9",
    "@types/jsonpath-plus": "^5.0.5",
    "@types/node": "^20.11.17",
    "@types/tap": "^15.0.12",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.1.0",
    "hono": "^4.11.5",
    "husky": "^9.1.7",
    "ioredis": "^5.9.2",
    "ioredis-mock": "^8.13.1",
    "prettier": "^3.8.1",
    "tap": "^21.5.0",
    "typescript": "^5.8.3"
  }
}
