{
  "name": "@idempot/bun-handler",
  "version": "1.0.0",
  "description": "Bun.serve handler wrapper for idempotency",
  "type": "module",
  "main": "./index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./index.js"
    }
  },
