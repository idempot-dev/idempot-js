{
  "name": "@idempot/redis-store",
  "version": "1.0.0",
  "description": "Redis storage backend for idempotency",
  "type": "module",
  "main": "./node-redis.js",
  "types": "./types/node-redis.d.ts",
  "exports": {
    ".": {
      "types": "./types/node-redis.d.ts",
      "import": "./node-redis.js"
    },
    "./deno-redis.js": {
      "types": "./types/deno-redis.d.ts",
      "import": "./deno-redis.js"
    }
  },
  "files": [
    "node-redis.js",
    "deno-redis.js",
    "types",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "redis",
    "store",
    "idempotency",
    "idempotent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idempot-dev/idempot-js.git"
  },
  "license": "BSD-3-Clause",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build",
    "test": "tap tests/"
  },
  "peerDependencies": {
    "ioredis": ">=5.0.0"
  },
  "dependencies": {
    "@idempot/core": "workspace:*"
  }
}
