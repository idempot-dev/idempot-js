{
  "name": "@idempot/postgres-store",
  "version": "1.0.0",
  "description": "PostgreSQL storage backend for idempotency",
  "type": "module",
  "main": "./index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./index.js"
    }
  },
  "files": [
    "index.js",
    "types",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "postgres",
    "postgresql",
    "store",
    "idempotency",
    "idempotent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idempot-dev/idempot-js.git"
  },
  "license": "BSD-3-Clause",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build",
    "test": "tap tests/"
  },
  "peerDependencies": {
    "pg": ">=8.0.0"
  },
  "dependencies": {
    "@idempot/core": "workspace:*"
  }
}
